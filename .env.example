# --- BFF server (server/index.ts) ---
# Port for the local API server (Vite dev server proxies /api here)
PORT=8787

# CelesTrak GP data base URL
CELESTRAK_BASE_URL=https://celestrak.org

# SatNOGS DB (decoded telemetry, requires token) and Network (public observations)
SATNOGS_DB_BASE_URL=https://db.satnogs.org
SATNOGS_NETWORK_BASE_URL=https://network.satnogs.org

# SatNOGS DB API token. OPTIONAL.
# - The app starts and works without it; the Telemetry panel will show
#   "Telemetry token is not configured".
# - Get one at https://db.satnogs.org (account required).
# - This token is ONLY used server-side. It is never sent to the browser,
#   never logged, and never embedded in the client bundle.
SATNOGS_API_TOKEN=

# Server-side cache TTL for live data (seconds)
LIVE_DATA_CACHE_TTL_SECONDS=600
